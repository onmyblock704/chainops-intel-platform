
# =========================================================
# DATABASE
# =========================================================

DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/chainops


# =========================================================
# ALCHEMY
# =========================================================

VITE_ALCHEMY_API_KEY=your_alchemy_key

ALCHEMY_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/your_key


# =========================================================
# RPC
# =========================================================

